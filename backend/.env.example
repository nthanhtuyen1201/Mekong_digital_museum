# File cấu hình biến môi trường cho ứng dụng Museum
# Copy file này thành .env và điền thông tin thực tế

# Flask Secret Key (dùng cho session)
SECRET_KEY=your-secret-key-here-change-in-production

# Tài khoản Admin mặc định (chỉ dùng khi khởi tạo lần đầu)
ADMIN_USER=admin
ADMIN_PASS=12345

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=mekong_museum
